# Svetovid talks to a running DaVinci Resolve Studio over its scripting API.
# These are auto-detected per platform, so you usually need nothing here.
# Set them only if Resolve is installed somewhere non-standard.

# RESOLVE_SCRIPT_API="/Library/Application Support/Blackmagic Design/DaVinci Resolve/Developer/Scripting"
# RESOLVE_SCRIPT_LIB="/Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/Libraries/Fusion/fusionscript.so"
